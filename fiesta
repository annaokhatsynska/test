  <style>
    /* Map design fonts to available alternatives */
    :root {
      --font-body: 'Nunito Sans', system-ui, sans-serif;
      --font-heading: 'Nunito Sans', system-ui, sans-serif;
    }
    * { box-sizing: border-box; }
    body { font-family: var(--font-body); margin: 0; background: #fff; }

    /* Toggle switch */
    .toggle {
      position: relative;
      display: inline-block;
      width: 42px;
      height: 20px;
      border-radius: 10px;
      border: 1px solid #2e3134;
      background: #e8eaed;
      cursor: pointer;
      flex-shrink: 0;
    }
    .toggle::after {
      content: '';
      position: absolute;
      top: -3px;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #fff;
      border: 1px solid #dadce0;
      box-shadow: 0 1px 3px rgba(0,0,0,.3);
      transition: left .15s;
    }
    .toggle.off::after { left: -1px; }
    .toggle.on::after  { left: 17px; background: #2e3134; border-color: #2e3134; }

    /* Checkbox */
    .cb { width: 20px; height: 20px; flex-shrink: 0; border: 1.5px solid #5f6368; border-radius: 3px; margin-top: 2px; }
    .cb.checked { background: #0e1013; border-color: #0e1013; display: flex; align-items: center; justify-content: center; }

    /* Active nav underline */
    .nav-active { position: relative; color: #fff !important; }
    .nav-active::after {
      content: '';
      position: absolute;
      left: 0; right: 0;
      bottom: -18px;
      height: 2px;
      background: #fff;
      border-radius: 2px;
    }

    /* Selected tab */
    .tab-selected {
      background: #fff;
      border: 1px solid #dadce0;
      border-bottom: none;
      border-radius: 8px 8px 0 0;
      position: relative;
    }
    .tab-selected::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 1px;
      right: 1px;
      height: 1px;
      background: #fff;
      z-index: 1;
    }

    /* iPad frame effect */
    .ipad-border {
      border: 17px solid #2e3134;
      border-radius: 25px;
    }

    /* ── Asset card states ── */
    .asset-card {
      cursor: pointer;
      transition: border-color .12s, background .12s, box-shadow .12s;
      outline: none;
    }
    /* Default */
    .asset-card              { border-color: #dadce0; }
    .asset-card .card-bg     { background: #f8f9fa; }
    .asset-card .card-label  { color: #3c4043; }

    /* Hover */
    .asset-card:hover                  { border-color: #9aa0a6; box-shadow: 0 1px 4px rgba(0,0,0,.10); }
    .asset-card:hover .card-bg         { background: #f1f3f4; }

    /* Selected (dark border) */
    .asset-card.selected               { border-color: #2e3134 !important; box-shadow: none; }
    .asset-card.selected .card-bg      { background: #f1f3f4 !important; }
    .asset-card.selected .card-label   { color: #0e1013 !important; font-weight: 600; }

    /* Focused (keyboard nav) */
    .asset-card:focus-visible          { outline: 2px solid #2e3134; outline-offset: 2px; border-color: #2e3134; }

    /* Disabled */
    .asset-card.disabled               { border-color: #dadce0 !important; opacity: 0.38; cursor: not-allowed; pointer-events: none; }

    /* Scrollbar thin */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #dadce0; border-radius: 4px; }
  </style>
